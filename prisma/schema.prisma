// CodeShift data model
// Run: npx prisma generate && npx prisma db push

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Auth ───────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())

  accounts           Account[]
  sessions           Session[]
  projects           Project[]
  creditTransactions CreditTransaction[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────── Credits ───────────────────────────

enum CreditTransactionType {
  PURCHASE
  CONSUMPTION
  REFUND
  SIGNUP_BONUS
}

// Append-only ledger. A user's balance is SUM(amount) — there is deliberately
// no denormalized balance column, so the ledger is always the source of truth.
model CreditTransaction {
  id                    String                @id @default(cuid())
  userId                String
  amount                Int // positive = purchase/refund/bonus, negative = consumption
  type                  CreditTransactionType
  migrationId           String? // set for CONSUMPTION and REFUND
  stripePaymentIntentId String?               @unique // webhook idempotency key for PURCHASE
  createdAt             DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([migrationId])
}

// ─────────────────────────── Core domain ───────────────────────────

enum ProjectStatus {
  UPLOADED   // files received, not yet analyzed
  ANALYZING
  ANALYZED   // analysis report ready, migration plan proposed
  MIGRATING
  COMPLETED
  FAILED
}

enum MigrationPath {
  PHP_TO_LARAVEL
  JQUERY_TO_REACT
  WORDPRESS_TO_NEXTJS
  PYTHON2_TO_PYTHON3
  ANGULARJS_TO_REACT
  VANILLA_TO_VUE
  CUSTOM
}

model Project {
  id            String        @id @default(cuid())
  userId        String
  name          String
  status        ProjectStatus @default(UPLOADED)
  sourcePath    MigrationPath?
  targetStack   String?       // e.g. "Laravel 11 + Inertia + React"
  designStyle   String?       // chosen frontend redesign style
  riskLevel     String?       // LOW | MEDIUM | HIGH

  // metrics surfaced on the dashboard
  fileCount     Int           @default(0)
  totalBytes    Int           @default(0)
  detectedStack Json?         // { framework, version, language, deps }

  paid          Boolean       @default(false)
  priceCents    Int           @default(0)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  files     SourceFile[]
  analysis  Analysis?
  migration Migration?

  @@index([userId])
}

// A file from the uploaded legacy codebase
model SourceFile {
  id          String  @id @default(cuid())
  projectId   String
  path        String  // relative path inside the repo
  content     String  @db.Text
  language    String?
  bytes       Int     @default(0)

  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  migratedFile     MigratedFile?

  @@index([projectId])
}

// Output of the Smart Codebase Analysis phase
model Analysis {
  id            String   @id @default(cuid())
  projectId     String   @unique
  summary       String   @db.Text
  framework     String?
  frameworkVer  String?
  language      String?
  dependencies  Json?    // [{ name, version, status: ok|outdated|vulnerable, replacement }]
  risks         Json?    // [{ severity, title, detail, files: [] }]
  dependencyGraph Json?  // { nodes: [], edges: [] } for visualization
  recommendedPath MigrationPath?
  recommendedStack String?
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum MigrationStatus {
  PENDING
  PLANNING
  REWRITING
  TESTING
  DOCUMENTING
  DONE
  FAILED
}

// Output of the Intelligent Code Rewriting phase
model Migration {
  id            String          @id @default(cuid())
  projectId     String          @unique
  status        MigrationStatus @default(PENDING)
  plan          Json?           // ordered list of steps the engine will take
  progress      Int             @default(0) // 0-100
  currentStep   String?
  readme        String?         @db.Text
  apiDocs       String?         @db.Text
  testSummary   String?         @db.Text
  tokensUsed    Int             @default(0)
  cacheReadTokens Int           @default(0)
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime        @default(now())

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  files   MigratedFile[]
}

// A rewritten file, paired to its source for the diff viewer
model MigratedFile {
  id            String  @id @default(cuid())
  migrationId   String
  sourceFileId  String? @unique
  path          String  // new path in the modern project
  content       String  @db.Text
  language      String?
  explanation   String? @db.Text // why the engine made these changes
  isNew         Boolean @default(false) // file with no legacy counterpart
  testContent   String? @db.Text // generated test for this file

  // Closed-loop verification results
  verified      Boolean @default(false) // passed verification (no errors, high confidence)
  confidence    Int     @default(0)     // 0-100 combined confidence score
  behaviorParity Int    @default(0)     // 0-100 behavior-preservation score
  repairRounds  Int     @default(0)     // self-repair passes taken
  diagnostics   Json?                   // [{ severity, category, message, suggestion, line }]

  migration  Migration   @relation(fields: [migrationId], references: [id], onDelete: Cascade)
  sourceFile SourceFile? @relation(fields: [sourceFileId], references: [id], onDelete: SetNull)

  @@index([migrationId])
}
