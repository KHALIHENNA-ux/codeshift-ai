# ─── Anthropic (the modernization engine runs on Claude) ───
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Database (Postgres) ───
DATABASE_URL="postgresql://user:password@localhost:5432/codeshift?schema=public"

# ─── Auth ───
# Generate with: openssl rand -base64 32
AUTH_SECRET=changeme
NEXTAUTH_URL=http://localhost:3000

# OAuth providers (optional — email/password works without these)
GITHUB_ID=
GITHUB_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Stripe (credit-pack billing) ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Credit-pack Price IDs — create with: node scripts/stripe-setup-credits.mjs (test mode)
# For production, create the live Products/Prices in the Stripe Dashboard.
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_SCALE=price_...

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
