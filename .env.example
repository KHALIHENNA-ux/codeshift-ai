# ─── Anthropic (the modernization engine runs on Claude) ───
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Database (Postgres) ───
DATABASE_URL="postgresql://user:password@localhost:5432/codeshift?schema=public"

# ─── Auth ───
# Generate with: openssl rand -base64 32
AUTH_SECRET=changeme
NEXTAUTH_URL=http://localhost:3000

# OAuth providers (optional — email/password works without these)
GITHUB_ID=
GITHUB_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Stripe (per-migration billing) ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
